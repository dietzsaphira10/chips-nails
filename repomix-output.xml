import { useRef, useState, useEffect } from "react";

const StorySection = () => {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });

  // --- DSGVO STATE & LOGIK ---
  const [hasFullConsent, setHasFullConsent] = useState(false);

  useEffect(() => {
    // Liest SOFORT beim Laden der Komponente den Status aus
    const consent = localStorage.getItem("cookieConsent");
    setHasFullConsent(consent === "all");

    // Hört zusätzlich auf Änderungen (falls der User JETZT GERADE klickt)
    const handleConsentChange = () => {
      setHasFullConsent(localStorage.getItem("cookieConsent") === "all");
    };

    window.addEventListener("cookieConsentChanged", handleConsentChange);
    return () => window.removeEventListener("cookieConsentChanged", handleConsentChange);
  }, []);

  // TikTok Script laden, wenn Zustimmung da ist
  useEffect(() => {
    if (hasFullConsent) {
      const script = document.createElement("script");
      script.src = "https://www.tiktok.com/embed.js";
      script.async = true;
      document.body.appendChild(script);
    }
  }, [hasFullConsent]);


<file path="src/components/CookieBanner.tsx">
import { useState, useEffect } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { Link } from "react-router-dom";

const CookieBanner = () => {
  const [isVisible, setIsVisible] = useState(false);

  useEffect(() => {
    const consent = localStorage.getItem("cookieConsent");
    if (!consent) {
      setIsVisible(true);
    }
  }, []);

  const acceptAll = () => {
    localStorage.setItem("cookieConsent", "all");
    window.dispatchEvent(new Event("cookieConsentChanged")); // NEU: Sendet das Signal an die Seite
    setIsVisible(false);
  };

  const acceptEssential = () => {
    localStorage.setItem("cookieConsent", "essential");
    window.dispatchEvent(new Event("cookieConsentChanged")); // NEU
    setIsVisible(false);
  };

  return (
    <AnimatePresence>
      {isVisible && (
        <motion.div
          initial={{ y: 100, opacity: 0 }}
          animate={{ y: 0, opacity: 1 }}
          exit={{ y: 100, opacity: 0 }}
          transition={{ duration: 0.8, ease: "easeOut" }}
          className="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl border-t border-black/10 p-6 md:p-8 shadow-[0_-10px_40px_rgba(0,0,0,0.05)] flex flex-col md:flex-row items-center justify-between gap-8"
        >
          <div className="max-w-4xl text-center md:text-left">
            <h3 className="text-black uppercase text-xs md:text-sm tracking-[0.2em] mb-3" style={{ fontFamily: "'Montserrat', sans-serif", fontWeight: 500 }}>
              Privatsphäre & Cookies
            </h3>
            <p className="text-black/60 text-[10px] md:text-xs leading-[1.8]" style={{ fontFamily: "'Montserrat', sans-serif", fontWeight: 300 }}>
              Um dir das bestmögliche Erlebnis zu bieten, nutzen wir auf unserer Website Cookies sowie externe Dienste wie Google Maps und TikTok. Du kannst selbst entscheiden, welche Daten du teilen möchtest. Weitere Details findest du in unserer <Link to="/datenschutz" className="text-black underline decoration-black/30 underline-offset-4 hover:decoration-black transition-all">Datenschutzerklärung</Link>.
            </p>
          </div>
          
          <div className="flex flex-col sm:flex-row gap-4 w-full md:w-auto shrink-0">
            <button
              onClick={acceptEssential}
              className="px-6 py-3 border border-black/20 text-black/70 text-[10px] uppercase tracking-[0.2em] hover:bg-black/5 hover:text-black transition-colors"
              style={{ fontFamily: "'Montserrat', sans-serif", fontWeight: 400 }}
            >
              Nur Essenzielle
            </button>
            <button
              onClick={acceptAll}
              className="px-6 py-3 bg-black text-white text-[10px] uppercase tracking-[0.2em] hover:bg-black/80 transition-colors shadow-lg"
              style={{ fontFamily: "'Montserrat', sans-serif", fontWeight: 400 }}
            >
              Alle Akzeptieren
            </button>
          </div>
        </motion.div>
      )}
    </AnimatePresence>
  );
};

export default CookieBanner;
</file>

